# ContractIQ web app — copy to .env.local (git-ignored) and fill in.
# Never use NEXT_PUBLIC_ for sensitive values (they ship to the browser).

# Neon Postgres connection string (production data layer). See docs/DEPLOY.md.
# Local dev can run without this by proxying to the platform data server instead.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local dev only: where the Next API routes proxy to (the platform node:http
# server, started with `cd platform && npm run serve`). Unused in production.
PLATFORM_API=http://127.0.0.1:8787

NODE_ENV=development
