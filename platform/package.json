{
  "name": "contractiq-platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Data foundation for ContractIQ — cleared-defense total-compensation intelligence (see ../docs/STRATEGY.md).",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "download": "node src/download.mjs",
    "ingest": "node src/ingest.mjs",
    "report": "node src/report.mjs",
    "load-web": "node src/load-web-terms.mjs",
    "merge-web": "node src/merge-web.mjs",
    "terms": "node src/terms-report.mjs",
    "value": "node src/value.mjs",
    "compare": "node src/compare.mjs",
    "comp-check": "node src/comp-check.mjs",
    "seed-comp": "node src/comp/seed-dev-comp.mjs",
    "serve": "node src/server.mjs",
    "ping-neon": "node --env-file=../.env src/lib/ping-neon.mjs",
    "migrate-neon": "node --env-file=../.env src/migrate-postgres.mjs",
    "ingest-companies": "node --env-file=../.env src/ingest-companies.mjs",
    "enrich-web": "node --env-file=../.env src/enrich-web.mjs",
    "ingest-jobs": "node --env-file=../.env src/ingest-jobs.mjs",
    "fetch-logos": "node --env-file=../.env src/fetch-logos.mjs",
    "seed": "node src/download.mjs && node src/ingest.mjs && node src/report.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "adm-zip": "^0.5.16",
    "csv-parse": "^5.6.0",
    "pg": "^8.22.0"
  }
}
